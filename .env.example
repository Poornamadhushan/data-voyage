PORT=3000
NODE_ENV=production

# 32+ character random value (required in production)
SESSION_SECRET=replace-with-a-very-long-random-string

# Bootstrap initial admin (optional; app will only create it once)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ReplaceWithAStrongPassword123!

# SQLite database file (relative paths are relative to project root)
DB_PATH=./data/datavoyage.db

# Upload limit for paper files (bytes)
MAX_FILE_SIZE=52428800

# Optional: used for generating absolute callback URLs for OAuth links
# (set to https://yourdomain.com in production)
PUBLIC_BASE_URL=

# Optional: used for email verification links for change-email
BASE_URL=

# Optional: used for email links for password reset
APP_BASE_URL=

# Password reset token TTL (minutes)
RESET_TOKEN_TTL_MINUTES=30

# SMTP (optional; if not configured, the app will skip sending email)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FROM=
SMTP_USER=
SMTP_PASS=

# OAuth providers (all optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

